# AplicaГѓВ§ГѓВЈo
APP_NAME=Vidalys Pay
APP_BASE_URL=https://pay.vidalys.com.br
SECRET_KEY=troque-por-uma-chave-forte-minimo-50-caracteres
DEBUG=false
ALLOWED_HOSTS=pay.vidalys.com.br,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://pay.vidalys.com.br

# PostgreSQL (banco externo Гўв‚¬вЂќ use a URL interna do Coolify)
DATABASE_URL=postgresql://usuario:senha@host-interno:5432/vidalys_pay

# Pagar.me
# Aceita Secret Key original (sk_...), Base64 de "sk_...:" ou cabeГѓВ§alho "Basic ...".
# Prefira armazenar a Secret Key original no gerenciador de secrets.
PAGARME_CREDENTIAL=configure-no-coolify
PAGARME_BASE_URL=https://api.pagar.me/core/v5
PAGARME_WEBHOOK_AUTH_MODE=basic
PAGARME_WEBHOOK_BASIC_AUTH_USER=gere-um-segredo-forte
PAGARME_WEBHOOK_BASIC_AUTH_PASSWORD=gere-outro-segredo-forte

# Consulta de CNPJ (BrasilAPI, sem chave de autenticaГ§ГЈo)
CNPJ_LOOKUP_BASE_URL=https://brasilapi.com.br/api/cnpj/v1
CNPJ_LOOKUP_CONNECT_TIMEOUT_SECONDS=5
CNPJ_LOOKUP_READ_TIMEOUT_SECONDS=10
CNPJ_LOOKUP_USER_AGENT=Vidalys-Pay-CNPJ/1.0

# NotificaГ§Гµes de boletos
# Telefones E.164 separados por vГ­rgula. Vazio desabilita avisos aos gestores.
BOLETO_MANAGER_WHATSAPP_PHONES=
BOLETO_NOTIFY_CUSTOMER_ON_PAID=false
BOLETO_NOTIFY_CUSTOMER_ON_CANCELED=false
# Lembretes para boletos PENDING: 3 dias antes, no dia e 1 dia depois.
BOLETO_REMINDERS_ENABLED=true
BOLETO_REMINDER_DAYS=3,0,-1
BOLETO_REMINDER_SCAN_SECONDS=3600
BOLETO_REMINDER_TIME_ZONE=America/Sao_Paulo
BOLETO_REMINDER_WHATSAPP_ENABLED=true
# Habilite somente com autorizaГ§ГЈo para avisar o cliente por WhatsApp.
BOLETO_REMINDER_NOTIFY_CUSTOMER=false

# Evolution API
EVOLUTION_API_URL=https://evolution.seudominio.com
EVOLUTION_API_KEY=troque
EVOLUTION_INSTANCE=nome-da-instancia

# Acesso e API
INVITATION_EXPIRATION_HOURS=24
SELLER_SESSION_DAYS=30
INVITATION_TOKEN_PEPPER=gere-um-segredo-forte
API_KEY_PEPPER=gere-outro-segredo-distinto

# OperaГѓВ§ГѓВЈo
LOG_LEVEL=INFO
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
WORKER_POLL_SECONDS=3
MAX_NOTIFICATION_ATTEMPTS=5
OUTBOX_STALE_LOCK_SECONDS=600

# Correios CWS Гўв‚¬вЂќ cГѓВЎlculo de frete (apenas 6 variГѓВЎveis obrigatГѓВіrias)
CORREIOS_USUARIO=
CORREIOS_CODIGO_ACESSO=
CORREIOS_CARTAO_POSTAGEM=
CORREIOS_CONTRATO=
CORREIOS_CNPJ=
CORREIOS_CEP_ORIGEM=
# Dias adicionais somados ao prazo dos Correios (opcional, padrГѓВЈo 0)
CORREIOS_DIAS_ADICIONAIS=0

# Espera do banco (opcional Гўв‚¬вЂќ valores padrГѓВЈo abaixo)
DB_WAIT_MAX_ATTEMPTS=60
DB_WAIT_INTERVAL_SECONDS=2
DB_CONNECT_TIMEOUT_SECONDS=5
# Web Push (gere as chaves VAPID antes de habilitar em produГ§ГЈo)
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=
WEBPUSH_VAPID_SUBJECT=mailto:contato@vidalys.com.br
