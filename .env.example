# Aplicação
APP_NAME=Vidalys Pay
APP_BASE_URL=https://pay.vidalys.com.br
SECRET_KEY=troque-por-uma-chave-forte-minimo-50-caracteres
DEBUG=false
ALLOWED_HOSTS=pay.vidalys.com.br
CSRF_TRUSTED_ORIGINS=https://pay.vidalys.com.br

# PostgreSQL (banco externo — use a URL interna do Coolify)
DATABASE_URL=postgresql://usuario:senha@host-interno:5432/vidalys_pay

# Pagar.me
PAGARME_BASE_URL=https://api.pagar.me/core/v5
PAGARME_SECRET_KEY=troque-pela-chave-de-producao
PAGARME_WEBHOOK_BASIC_AUTH_USER=gere-um-segredo-forte

# Evolution API
EVOLUTION_API_URL=https://evolution.seudominio.com
EVOLUTION_API_KEY=troque
EVOLUTION_INSTANCE=nome-da-instancia

# Acesso e API
INVITATION_EXPIRATION_HOURS=24
SELLER_SESSION_DAYS=30
INVITATION_TOKEN_PEPPER=gere-um-segredo-forte
API_KEY_PEPPER=gere-outro-segredo-distinto

# Operação
LOG_LEVEL=INFO
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
WORKER_POLL_SECONDS=3
MAX_NOTIFICATION_ATTEMPTS=5

# Espera do banco (opcional — valores padrão abaixo)
DB_WAIT_MAX_ATTEMPTS=60
DB_WAIT_INTERVAL_SECONDS=2
DB_CONNECT_TIMEOUT_SECONDS=5
